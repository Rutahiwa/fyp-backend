# ============================================
# UDSM Information Dissemination Platform
# Copy this file to .env.local and fill in values
# ============================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/udsm_platform
# For drizzle-kit push/migrate/introspection against Supabase, prefer the direct/session URL (port 5432),
# not the pooler URL (port 6543), if you still hit introspection errors.

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Resend (Email Service)
RESEND_API_KEY=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
OTP_EXPIRY_MINUTES=10

# Admin email for seed (optional; default admin@udsminfo.com)
ADMIN_EMAIL=admin@example.com
# Any one of these unlocks user seeding: admin + demo accounts share this password for bcrypt in one run
ADMIN_PASSWORD=
SEED_PASSWORD=
SEED_DEMO_PASSWORD=

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000

# Supabase Storage
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# File Upload
MAX_FILE_SIZE_MB=10
